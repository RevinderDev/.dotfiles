font-family = "IosevkaTerm Nerd Font"
font-size = 15

# Ghostty enables standard ligatures by default, but you can explicitly pass them:
font-feature = liga
font-feature = clig

# Window & Transparency
window-decoration = none
window-padding-x = 10
window-padding-y = 10

theme = Gruvbox Material Dark
background-opacity = 0.9
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
